{
    "version": 3,
    "configurePresets": [
        {
            "name": "aarch64-efi",
            "displayName": "AArch64 EFI (LLVM)",
            "toolchainFile": "${sourceDir}/cmake/toolchain-aarch64-efi.cmake",
            "binaryDir": "${sourceDir}/build/debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "aarch64-efi-release",
            "inherits": "aarch64-efi",
            "displayName": "AArch64 EFI Release (LLVM)",
            "binaryDir": "${sourceDir}/build/release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ]
}
